<clickhouse>
    <logger>
        <level>information</level>
        <console>true</console>
    </logger>

    <remote_servers>
        <sao_cluster>
            <shard>
                <replica>
                    <host>clickhouse-s1r1</host>
                    <port>9000</port>
                </replica>
                <replica>
                    <host>clickhouse-s1r2</host>
                    <port>9000</port>
                </replica>
            </shard>
            <shard>
                <replica>
                    <host>clickhouse-s2r1</host>
                    <port>9000</port>
                </replica>
                <replica>
                    <host>clickhouse-s2r2</host>
                    <port>9000</port>
                </replica>
            </shard>
        </sao_cluster>
    </remote_servers>

    <zookeeper>
        <node>
            <host>zookeeper</host>
            <port>2181</port>
        </node>
    </zookeeper>

    <macros>
        <shard from_env="CLICKHOUSE_SHARD"/>
        <replica from_env="CLICKHOUSE_REPLICA"/>
        <cluster>sao_cluster</cluster>
    </macros>

    <distributed_ddl>
        <path>/clickhouse/task_queue/ddl</path>
    </distributed_ddl>

    <!-- Query logging for attack observability -->
    <query_log>
        <database>system</database>
        <table>query_log</table>
        <flush_interval_milliseconds>1000</flush_interval_milliseconds>
    </query_log>

    <query_thread_log>
        <database>system</database>
        <table>query_thread_log</table>
        <flush_interval_milliseconds>1000</flush_interval_milliseconds>
    </query_thread_log>
</clickhouse>
